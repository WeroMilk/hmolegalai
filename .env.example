# App URL (producción). Ej: https://tu-dominio.vercel.app
NEXT_PUBLIC_APP_URL=

# Firebase Configuration
# Poner NEXT_PUBLIC_FIREBASE_ENABLED=true cuando tengas las credenciales
NEXT_PUBLIC_FIREBASE_ENABLED=true
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (verificación de tokens en el servidor)
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY=your_private_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_publishable_key
STRIPE_SECRET_KEY=your_secret_key
STRIPE_WEBHOOK_SECRET=your_webhook_signing_secret

# OpenAI (planes nutricionales)
OPENAI_API_KEY=your_openai_api_key

# Notificaciones (opcional: email a la nutrióloga al enviar consulta)
NUTRITIONIST_EMAIL=your_nutritionist_email
RESEND_API_KEY=your_resend_api_key

# WhatsApp (botón flotante)
NEXT_PUBLIC_WHATSAPP_NUMBER=521XXXXXXXXXX
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hola%2C%20tengo%20una%20duda%20sobre%20nutrici%C3%B3n
