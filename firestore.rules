rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Perfil de usuario (nutrióloga y clientes)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Consultas del formulario: solo el backend (Admin SDK) crea; nutrióloga/admin lee
    match /consultas/{consultaId} {
      allow read: if request.auth != null;
      allow create: if false;
      allow update, delete: if request.auth != null;
    }
    // Órdenes de la tienda: creación desde API; lectura/actualización por admin
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    // Productos (stock, etc.): solo backend o admin
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
